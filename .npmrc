# Хостим зависимости нативных модулей в корневой node_modules, чтобы
# Next.js standalone output трассировщик мог их увидеть. Без этого:
#
# 1) better-sqlite3 не находит `bindings` — оно загружается через
#    динамический require с вычисленным путём (статический анализ
#    Next.js это не видит).
# 2) @node-rs/argon2 не находит `@node-rs/argon2-linux-arm64-gnu`
#    (или -x64-gnu на amd64) — платформо-специфичные subpackages лежат
#    в .pnpm/ и не симлинкованы в корневой node_modules.
# 3) sharp аналогично — `@img/sharp-linux-*` и `@img/sharp-libvips-linux-*`
#    не попадают в корневой node_modules/@img/.
#
# С этими паттернами pnpm создаёт симлинки node_modules/<pkg> → .pnpm/...,
# и трассировщик корректно резолвит транзитивные зависимости.
public-hoist-pattern[]=bindings
public-hoist-pattern[]=file-uri-to-path
public-hoist-pattern[]=node-gyp-build
public-hoist-pattern[]=@node-rs/argon2-*
public-hoist-pattern[]=@img/sharp-*
public-hoist-pattern[]=@img/sharp-libvips-*
