# Хостим зависимости нативных модулей в корневой node_modules, чтобы
# Next.js standalone output трассировщик мог их увидеть. better-sqlite3
# загружает `bindings` динамически (require по вычисленному пути), из-за
# чего статический анализ Next.js не захватывает пакет в outputFileTracing.
# С этим паттерном pnpm создаёт симлинк node_modules/bindings → .pnpm/...,
# и трассировщик корректно резолвит транзитивную зависимость.
public-hoist-pattern[]=bindings
public-hoist-pattern[]=file-uri-to-path
public-hoist-pattern[]=node-gyp-build
