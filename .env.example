# Порт приложения. Используется:
#   1) docker-compose.yml для маппинга host:container
#   2) standalone server Next.js (PORT env var)
#   3) локальным next start (pnpm start)
PORT=3000

DATABASE_URL=file:./data/lunchhunter.db

# Seed admin credentials — используются в src/lib/db/seed.ts для создания
# одного admin-пользователя. В production замени ADMIN_PASSWORD на сильный.
ADMIN_EMAIL=admin@lunchhunter.local
ADMIN_PASSWORD=admin12345

# OpenRouter LLM — используется для vision OCR меню и недельного
# бизнес-ланча (src/lib/llm). Модель по умолчанию — x-ai/grok-4-fast.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=x-ai/grok-4-fast

# Telegram Mini App — токен бота из @BotFather. Используется в
# src/app/api/auth/telegram/route.ts для HMAC-верификации initData
# (src/lib/auth/telegram.ts).
TELEGRAM_BOT_TOKEN=

# Web Push (VAPID) — используется для push-уведомлений в PWA.
# Сгенерировать: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
